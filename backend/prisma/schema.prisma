generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id String @id @default(uuid())

  adminName     String
  adminEmail    String
  representante String
  fantasyName   String
  legalName     String
  cnpj          String @unique
  cnpj_status   String // "VALID", "INVALID"
  phone         String
  cep           String
  state         String
  city          String
  address       String

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cnpj])
}

model User {
  id String @id @default(uuid())

  name     String
  email    String @unique
  password String

  role Role @default(EMPLOYEE)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([role])
}

model AuditLog {
  id String @id @default(cuid())

  userId    String?
  userEmail String?
  companyId String?
  action    String // e.g. "USER_CREATED", "ORDER_UPDATED"
  entity    String // e.g. "User", "Order", "Product"
  entityId  String?
  metadata  Json? // flexible payload (before/after, extra info)
  ip        String?
  userAgent String?
  requestId String?
  status    String // "SUCCESS" | "FAILURE"
  error     String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([companyId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
}

enum Role {
  OWNER
  COMPANY_ADMIN
  EMPLOYEE
}
